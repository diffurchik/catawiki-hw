{
  "name": "catawiki-hw",
  "version": "1.0.0",
  "description": "TypeScript Playwright E2E test project",
  "scripts": {
    "prepare": "husky",
    "test": "npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "browsers:install": "playwright install",
    "lint": "eslint \"playwright.config.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint \"playwright.config.ts\" \"tests/**/*.ts\" --fix",
    "lint:staged": "lint-staged",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "report:allure": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diffurchik/catawiki-hw.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/diffurchik/catawiki-hw/issues"
  },
  "homepage": "https://github.com/diffurchik/catawiki-hw#readme",
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,mjs,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "allure-commandline": "^2.42.0",
    "allure-playwright": "^3.9.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
